## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.suo
*.user
.vs
!.gitignore
.claude/

# Build results
[Dd]ebug/
[Rr]elease/
x64/
[Bb]in/
[Oo]bj/

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
*.log

# Click-Once directory
publish/
artifacts/

# Publish Web Output
*.Publish.xml
*.pubxml
*.azurePubxml

# Generated XML documentation files (produced into bin/ via GenerateDocumentationFile)
**/Properties/*.xml

# Test result files
test-results/

